@page "/productos"
@using VentasPro.Application.Interfaces
@using VentasPro.Application.Features.Productos.DTOs
@inject IProductoService ProductoService
@rendermode InteractiveServer

<h3>Productos</h3>

<EditForm Model="@filtro" OnSubmit="Filtrar" FormName="filtroProductosForm">
    <div class="mb-3 d-flex gap-2 flex-wrap align-items-end">
        <div class="flex-grow-1" style="min-width: 250px;">
            <label class="form-label">Buscar</label>
            <InputText @bind-Value="filtro.TextoBusqueda" class="form-control" placeholder="Nombre o código de barras..." />
        </div>
        
        <div>
            <label class="form-label">Estado</label>
            <InputSelect @bind-Value="filtro.Estado" class="form-select">
                <option value="todos">Todos</option>
                <option value="activos">Solo Activos</option>
                <option value="inactivos">Solo Inactivos</option>
            </InputSelect>
        </div>
        
        <button type="submit" class="btn btn-secondary">
            <i class="bi bi-search"></i> Buscar
        </button>
        
        <a href="/productos/nuevo" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo
        </a>
    </div>
</EditForm>

@if (productosOriginal == null)
{
    <p><em>Cargando...</em></p>
}
else if (!productos.Any())
{
    <div class="alert alert-info">No se encontraron productos.</div>
}
else
{
    <table class="table table-striped col-12 mt-3">
        <thead>
            <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var producto in productos)
            {
                <tr class="@(producto.Activo ? "" : "table-secondary")">
                    <td>@producto.CodigoBarras</td>
                    <td>@producto.Nombre</td>
                    <td>@producto.Precio.ToString("C")</td>
                    <td>@producto.Stock</td>
                    <td>
                        <span class="badge @(producto.Activo ? "bg-success" : "bg-secondary")">
                            @(producto.Activo ? "Activo" : "Inactivo")
                        </span>
                    </td>
                    <td>
                        <a href="/productos/editar/@producto.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        @if (producto.Activo)
                        {
                            <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(producto.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => Activar(producto.Id)">
                                <i class="bi bi-check-circle"></i>
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <div class="text-muted">
        Mostrando @productos.Count() de @productosOriginal.Count() productos
    </div>
}

@code {
    private IEnumerable<ProductoDto>? productosOriginal;
    private IEnumerable<ProductoDto>? productos;
    private FiltroProducto filtro = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        bool? soloActivos = filtro.Estado switch
        {
            "activos" => true,
            "inactivos" => false,
            _ => null
        };

        productosOriginal = await ProductoService.GetAllAsync(soloActivos);
        AplicarFiltro();
    }

    private void AplicarFiltro()
    {
        if (string.IsNullOrWhiteSpace(filtro.TextoBusqueda))
        {
            productos = productosOriginal;
        }
        else
        {
            var termino = filtro.TextoBusqueda.ToLower().Trim();
            productos = productosOriginal?.Where(p =>
                (p.Nombre != null && p.Nombre.ToLower().Contains(termino)) ||
                (p.CodigoBarras != null && p.CodigoBarras.ToLower().Contains(termino))
            );
        }
    }

    private async Task Filtrar()
    {
        await CargarProductos();
    }

    private async Task Eliminar(int id)
    {
        await ProductoService.DeleteAsync(id);
        await CargarProductos();
    }

    private async Task Activar(int id)
    {
        await ProductoService.ActivateAsync(id);
        await CargarProductos();
    }

    private class FiltroProducto
    {
        public string TextoBusqueda { get; set; } = string.Empty;
        public string Estado { get; set; } = "todos";
    }
}