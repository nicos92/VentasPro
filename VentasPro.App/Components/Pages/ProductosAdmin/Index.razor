@page "/productos"
@using VentasPro.Application.Interfaces
@using VentasPro.Application.Features.Productos.DTOs
@inject IProductoService ProductoService
@rendermode InteractiveServer

<h3>Productos</h3>

<div class="mb-3 d-flex gap-2">
    <select class="form-select w-auto" @bind="filtroActivos">
        <option value="todos">Todos</option>
        <option value="activos">Solo Activos</option>
        <option value="inactivos">Solo Inactivos</option>
    </select>
    <button class="btn btn-secondary" @onclick="Filtrar">Filtrar</button>
    <a href="/productos/nuevo" class="btn btn-primary">Nuevo Producto</a>
</div>

@if (productos == null)
{
    <p><em>Cargando...</em></p>
}
else if (!productos.Any())
{
    <div class="alert alert-info">No hay productos registrados.</div>
}
else
{
    <table class="table table-striped col-12">
        <thead>
            <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var producto in productos)
            {
                <tr class="@(producto.Activo ? "" : "table-secondary")">
                    <td>@producto.CodigoBarras</td>
                    <td>@producto.Nombre</td>
                    <td>@producto.Precio.ToString("C")</td>
                    <td>@producto.Stock</td>
                    <td>
                        <span class="badge @(producto.Activo ? "bg-success" : "bg-secondary")">
                            @(producto.Activo ? "Activo" : "Inactivo")
                        </span>
                    </td>
                    <td>
                        <a href="/productos/editar/@producto.Id" class="btn btn-sm btn-warning">Editar</a>
                        @if (producto.Activo)
                        {
                            <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(producto.Id)">Desactivar</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => Activar(producto.Id)">Activar</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<ProductoDto>? productos;
    private string filtroActivos = "todos";

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        bool? soloActivos = filtroActivos switch
        {
            "activos" => true,
            "inactivos" => false,
            _ => null
        };

        productos = await ProductoService.GetAllAsync(soloActivos);
    }

    private async Task Filtrar()
    {
        await CargarProductos();
    }

    private async Task Eliminar(int id)
    {
        await ProductoService.DeleteAsync(id);
        await CargarProductos();
    }

    private async Task Activar(int id)
    {
        await ProductoService.ActivateAsync(id);
        await CargarProductos();
    }
}