@page "/productos/editar/{Id:int}"
@using VentasPro.Application.Interfaces
@using VentasPro.Application.Features.Productos.Commands
@using VentasPro.Application.Features.Productos.DTOs
@using VentasPro.Application.Features.Categorias.DTOs
@inject IProductoService ProductoService
@inject ICategoriaService CategoriaService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<h3>Editar Producto</h3>

@if (command == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <EditForm Model="@command" OnValidSubmit="HandleValidSubmit" FormName="editarProductoForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <InputText @bind-Value="command.Nombre" class="form-control" />
            <ValidationMessage For="@(() => command.Nombre)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <InputTextArea @bind-Value="command.Descripcion" class="form-control" rows="3" />
            <ValidationMessage For="@(() => command.Descripcion)" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Precio</label>
                <InputNumber @bind-Value="command.Precio" class="form-control" />
                <ValidationMessage For="@(() => command.Precio)" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Stock</label>
                <InputNumber @bind-Value="command.Stock" class="form-control" />
                <ValidationMessage For="@(() => command.Stock)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Código de Barras</label>
                <InputText @bind-Value="command.CodigoBarras" class="form-control" />
                <ValidationMessage For="@(() => command.CodigoBarras)" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Categoría</label>
                <InputSelect @bind-Value="command.CategoriaId" class="form-control">
                    <option value="">-- Seleccionar Categoría --</option>
                    @if (categorias != null)
                    {
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat.Id">@cat.Nombre</option>
                        }
                    }
                </InputSelect>
            </div>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle"></i> Guardar
            </button>
            <a href="/productos" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i> Cancelar
            </a>
        </div>

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle"></i> @mensajeError
            </div>
        }
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateProductoCommand? command;
    private IEnumerable<CategoriaDto>? categorias;

    protected override async Task OnInitializedAsync()
    {
        var producto = await ProductoService.GetByIdAsync(Id);
        categorias = await CategoriaService.GetAllAsync(true);

        if (producto != null)
        {
            command = new UpdateProductoCommand
            {
                Id = producto.Id,
                Nombre = producto.Nombre,
                Descripcion = producto.Descripcion,
                Precio = producto.Precio,
                Stock = producto.Stock,
                CodigoBarras = producto.CodigoBarras,
                CategoriaId = producto.CategoriaId
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        if (command != null)
        {
            try
            {
                await ProductoService.UpdateAsync(command);
                NavigationManager.NavigateTo("/productos");
            }
            catch (InvalidOperationException ex)
            {
                mensajeError = ex.Message;
            }
            catch (Exception ex)
            {
                mensajeError = "Ocurrió un error al guardar el producto.";
            }
        }
    }

    private string? mensajeError;
}