@page "/clientes"
@using VentasPro.Domain.Repositories
@using VentasPro.Domain.Entities
@inject IClienteRepository ClienteRepository

<h3>Clientes</h3>

<div class="mb-3">
    <a href="/clientes/nuevo" class="btn btn-primary">Nuevo Cliente</a>
</div>

@if (clientes == null)
{
    <p><em>Cargando...</em></p>
}
else if (!clientes.Any())
{
    <div class="alert alert-info">No hay clientes registrados.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Identificación</th>
                <th>Nombre</th>
                <th>Email</th>
                <th>Teléfono</th>
                <th>Dirección</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cliente in clientes)
            {
                <tr>
                    <td>@cliente.Identificacion</td>
                    <td>@cliente.NombreCompleto</td>
                    <td>@cliente.Email</td>
                    <td>@cliente.Telefono</td>
                    <td>@cliente.Direccion</td>
                    <td>
                        <a href="/clientes/editar/@cliente.Id" class="btn btn-sm btn-warning">Editar</a>
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(cliente.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<Cliente>? clientes;

    protected override async Task OnInitializedAsync()
    {
        clientes = await ClienteRepository.GetAllAsync();
    }

    private async Task Eliminar(int id)
    {
        await ClienteRepository.DeleteAsync(id);
        clientes = await ClienteRepository.GetAllAsync();
    }
}