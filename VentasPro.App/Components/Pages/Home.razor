@page "/"

<PageTitle>Inicio</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">Sistema de Ventas</h1>
    
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Productos</h5>
                    <p class="card-text">Gestionar el catálogo de productos</p>
                    <a href="/productos" class="btn btn-primary">Ir a Productos</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Clientes</h5>
                    <p class="card-text">Administrar clientes registrados</p>
                    <a href="/clientes" class="btn btn-primary">Ir a Clientes</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Ventas</h5>
                    <p class="card-text">Registrar nuevas ventas</p>
                    <a href="/ventas" class="btn btn-primary">Ir a Ventas</a>
                </div>
            </div>
        </div>
    </div>
</div>