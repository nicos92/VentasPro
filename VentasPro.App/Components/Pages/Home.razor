@page "/"
@using VentasPro.Application.Interfaces
@using VentasPro.Application.Features.Dashboard.DTOs
@inject IDashboardService DashboardService
@rendermode InteractiveServer

<PageTitle>Dashboard</PageTitle>

@if (dashboard == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <h3 class="mb-4">Dashboard</h3>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h6 class="card-title">Productos</h6>
                    <h2 class="mb-0">@dashboard.TotalProductos</h2>
                    <small>Activos: @dashboard.ProductosActivos</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h6 class="card-title">Clientes</h6>
                    <h2 class="mb-0">@dashboard.TotalClientes</h2>
                    <small>Activos: @dashboard.ClientesActivos</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h6 class="card-title">Categorías</h6>
                    <h2 class="mb-0">@dashboard.TotalCategorias</h2>
                    <small>Activas: @dashboard.CategoriasActivas</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h6 class="card-title">Ventas</h6>
                    <h2 class="mb-0">@dashboard.TotalVentas</h2>
                    <small>Completadas: @dashboard.VentasCompletadas</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-currency-dollar"></i> Estadísticas de Ventas</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-6">Ventas Totales:</dt>
                        <dd class="col-6">@dashboard.TotalVentas</dd>
                        
                        <dt class="col-6">Completadas:</dt>
                        <dd class="col-6">@dashboard.VentasCompletadas</dd>
                        
                        <dt class="col-6">Canceladas/Anuladas:</dt>
                        <dd class="col-6">@dashboard.VentasCanceladas</dd>
                        
                        <dt class="col-6">Monto Total:</dt>
                        <dd class="col-6 text-success fw-bold">@dashboard.VentasTotalesMonto.ToString("N2")</dd>
                        
                        <dt class="col-6">Promedio por Venta:</dt>
                        <dd class="col-6">@dashboard.VentasPromedio.ToString("N2")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-box-seam"></i> Inventario</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-6">Total Productos:</dt>
                        <dd class="col-6">@dashboard.TotalProductos</dd>
                        
                        <dt class="col-6">Productos Activos:</dt>
                        <dd class="col-6">@dashboard.ProductosActivos</dd>
                        
                        <dt class="col-6">Stock Bajo (≤10):</dt>
                        <dd class="col-6 text-danger fw-bold">@dashboard.CantidadProductosStockBajo</dd>
                        
                        <dt class="col-6">Valor Inventario:</dt>
                        <dd class="col-6">@dashboard.ValorTotalInventario.ToString("N2")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    @if (dashboard.ListaStockBajo.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Productos con Stock Bajo</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Código</th>
                            <th class="text-end">Precio</th>
                            <th class="text-center">Stock</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in dashboard.ListaStockBajo)
                        {
                            <tr>
                                <td>@p.Nombre</td>
                                <td>@p.CodigoBarras</td>
                                <td class="text-end">@p.Precio.ToString("N2")</td>
                                <td class="text-center">
                                    <span class="badge @GetStockBadge(p.Stock)">@p.Stock</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-clock-history"></i> Ventas Recientes</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (dashboard.VentasRecientes.Any())
                    {
                        @foreach (var v in dashboard.VentasRecientes)
                        {
                            <tr>
                                <td>@v.Id</td>
                                <td>@v.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@v.Cliente</td>
                                <td class="text-end">@v.Total.ToString("N2")</td>
                                <td>
                                    <span class="badge @GetEstadoBadge(v.Estado)">@v.Estado</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">No hay ventas registradas</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (dashboard.VentasPorMes.Valores.Any(v => v > 0))
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-bar-chart"></i> Ventas Últimos 6 Meses</h5>
            </div>
            <div class="card-body">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            @foreach (var label in dashboard.VentasPorMes.Labels)
                            {
                                <th class="text-center">@label</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            @foreach (var valor in dashboard.VentasPorMes.Valores)
                            {
                                <td class="text-center">
                                    <strong>@valor.ToString("N2")</strong>
                                </td>
                            }
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private DashboardDto? dashboard;

    protected override async Task OnInitializedAsync()
    {
        dashboard = await DashboardService.GetEstadisticasAsync();
    }

    private static string GetStockBadge(int stock)
    {
        return stock switch
        {
            <= 0 => "bg-danger",
            <= 5 => "bg-danger",
            <= 10 => "bg-warning",
            _ => "bg-secondary"
        };
    }

    private static string GetEstadoBadge(string estado)
    {
        return estado switch
        {
            "Completada" => "bg-success",
            "Pendiente" => "bg-warning",
            "Cancelada" => "bg-secondary",
            "Anulada" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}