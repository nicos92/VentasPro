@page "/ventas/nueva"
@using VentasPro.Application.Interfaces
@using VentasPro.Application.Features.Ventas.Commands
@using VentasPro.Application.Features.Ventas.DTOs
@using VentasPro.Application.Features.Productos.DTOs
@using VentasPro.Application.Features.Clientes.DTOs
@inject IVentaService VentaService
@inject IProductoService ProductoService
@inject IClienteService ClienteService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<h3>Nueva Venta</h3>

@if (productos == null || clientes == null)
{
    <p><em>Cargando...</em></p>
}
else if (!productos.Any())
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i>
        No hay productos disponibles. Debe tener productos activos con stock para poder realizar ventas.
    </div>
    <a href="/ventas" class="btn btn-secondary">Volver</a>
}
else
{
    <EditForm Model="@command" OnValidSubmit="HandleValidSubmit" FormName="crearVentaForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Cliente</label>
                <InputSelect @bind-Value="command.ClienteId" class="form-select">
                    <option value="">-- Sin Cliente --</option>
                    @foreach (var cli in clientes)
                    {
                        <option value="@cli.Id">@cli.NombreCompleto</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Método de Pago</label>
                <InputSelect @bind-Value="command.MetodoPago" class="form-select">
                    <option value="0">Efectivo</option>
                    <option value="1">Tarjeta de Crédito</option>
                    <option value="2">Tarjeta de Débito</option>
                    <option value="3">Transferencia</option>
                    <option value="4">Cheque</option>
                    <option value="5">Otro</option>
                </InputSelect>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0">Productos</h5>
            </div>
            <div class="card-body">
                @if (command.Detalles.Count == 0)
                {
                    <div class="alert alert-secondary text-center">
                        Agregue productos a la venta
                    </div>
                }
                else
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Precio</th>
                                <th>Cantidad</th>
                                <th>Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < command.Detalles.Count; i++)
                            {
                                var index = i;
                                var detalle = command.Detalles[i];
                                var producto = productos.FirstOrDefault(p => p.Id == detalle.ProductoId);
                                <tr>
                                    <td>@producto?.Nombre</td>
                                    <td>@producto?.PrecioVenta.ToString("N2")</td>
                                    <td>
                                        <input type="number" min="1" value="@detalle.Cantidad"
                                               @oninput="(e) => ActualizarCantidad(index, e)" class="form-control form-control-sm"
                                               style="width: 80px;" />
                                        <small class="text-muted">Stock: @producto?.Stock</small>
                                    </td>
                                    <td>@(((producto?.PrecioVenta ?? 0) * detalle.Cantidad).ToString("N2"))</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoverDetalle(index)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Código de Barras</label>
                        <div class="input-group">
                            <input type="text" class="form-control" @bind="CodigoBarras" @bind:event="oninput"
                                   placeholder="Escanear código de barras" />
                            <button type="button" class="btn btn-outline-secondary" @onclick="LimpiarCodigoBarras">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(mensajeErrorBarcode))
                        {
                            <small class="text-danger">@mensajeErrorBarcode</small>
                        }
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Buscar Producto</label>
                        <select class="form-select" @bind="productoSeleccionadoId">
                            <option value="0">-- Seleccionar Producto --</option>
                            @foreach (var prod in productos)
                            {
                                <option value="@prod.Id">@prod.Nombre - Stock: @prod.Stock - $@prod.PrecioVenta.ToString("N2")
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Cantidad</label>
                        <input type="number" class="form-control" @bind="cantidadAgregar" min="1" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="button" class="btn btn-primary w-100" @onclick="AgregarProducto">
                            <i class="bi bi-plus-circle"></i> Agregar
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(mensajeErrorProducto))
                {
                    <div class="alert alert-danger mt-2 mb-0">
                        <i class="bi bi-exclamation-triangle"></i> @mensajeErrorProducto
                    </div>
                }
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Notas</label>
            <InputTextArea @bind-Value="command.Notas" class="form-control" rows="2" />
        </div>

        <div class="card bg-light mb-3">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <label class="form-label">% Impuesto</label>
                        <InputNumber @bind-Value="command.PorcentajeImpuesto" class="form-control" min="0" max="100"
                                     step="0.01" />
                    </div>
                    <div class="col-md-8 text-end">
                        <div class="row mb-1">
                            <div class="col-8"><strong>Subtotal:</strong></div>
                            <div class="col-4">@Subtotal.ToString("N2")</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-8"><strong>Impuestos (@command.PorcentajeImpuesto%):</strong></div>
                            <div class="col-4">@Impuestos.ToString("N2")</div>
                        </div>
                        <div class="row">
                            <div class="col-8"><strong>
                                <h4>Total:</h4>
                            </strong></div>
                            <div class="col-4">
                                <h4 class="text-success">@Total.ToString("N2")</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle"></i> @mensajeError
            </div>
        }

        <div class="mb-3">
            <button type="button" class="btn btn-success" disabled="@(command.Detalles.Count == 0)" @onclick="MostrarConfirmacionRegistro">
                <i class="bi bi-check-circle"></i> Registrar Venta
            </button>
            <a href="/ventas" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i> Cancelar
            </a>
        </div>
    </EditForm>
}

@if (mostrarConfirmacion)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar Venta</h5>
                </div>
                <div class="modal-body">
                    <p><strong>¿Está seguro que desea registrar esta venta?</strong></p>
                    <ul class="list-group mb-3">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Productos:</span>
                            <span class="fw-bold">@command.Detalles.Count</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Subtotal:</span>
                            <span>@Subtotal.ToString("N2")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Impuestos (@command.PorcentajeImpuesto%):</span>
                            <span>@Impuestos.ToString("N2")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between fw-bold">
                            <span>Total:</span>
                            <span class="text-success">@Total.ToString("N2")</span>
                        </li>
                    </ul>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarConfirmacion = false">No, Volver</button>
                    <button class="btn btn-success" @onclick="ConfirmarRegistro">
                        <i class="bi bi-check-circle"></i> Sí, Registrar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private CreateVentaCommand command = new();
    private IEnumerable<ProductoDto>? productos;
    private IEnumerable<ClienteDto>? clientes;
    private Dictionary<string, ProductoDto> productosPorCodigo = new();
    private int productoSeleccionadoId = 0;
    private int cantidadAgregar = 1;
    private string? mensajeError;
    private string? mensajeErrorProducto;
    private string? mensajeErrorBarcode;
    private string codigoBarras = string.Empty;
    private bool mostrarConfirmacion = false;

    private string CodigoBarras
    {
        get => codigoBarras;
        set
        {
            codigoBarras = value;
            ProcesarCodigoBarras();
        }
    }

    private decimal Subtotal => command.Detalles.Sum(d =>
    {
        var prod = productos?.FirstOrDefault(p => p.Id == d.ProductoId);
        return (prod?.PrecioVenta ?? 0) * d.Cantidad;
    });

    private decimal Impuestos => Subtotal * (command.PorcentajeImpuesto / 100);
    private decimal Total => Subtotal + Impuestos;

    protected override async Task OnInitializedAsync()
    {
        productos = await ProductoService.GetAllAsync(true);
        clientes = await ClienteService.GetAllAsync(true);

        productosPorCodigo = productos!
                    .Where(p => !string.IsNullOrWhiteSpace(p.CodigoBarras))
                    .ToDictionary(p => p.CodigoBarras!.Trim().ToUpper(), p => p);
    }

    private void AgregarProducto()
    {
        mensajeErrorProducto = null;
        mensajeErrorBarcode = null;

        if (productoSeleccionadoId == 0)
        {
            mensajeErrorProducto = "Debe seleccionar un producto.";
            return;
        }

        if (cantidadAgregar <= 0)
        {
            mensajeErrorProducto = "La cantidad debe ser mayor a 0.";
            return;
        }

        var producto = productos?.FirstOrDefault(p => p.Id == productoSeleccionadoId);
        if (producto == null)
        {
            mensajeErrorProducto = "Producto no encontrado.";
            return;
        }

        AgregarProductoALista(producto.Id, cantidadAgregar);
        productoSeleccionadoId = 0;
        cantidadAgregar = 1;
    }

    private void ProcesarCodigoBarras()
    {
        if (string.IsNullOrWhiteSpace(codigoBarras))
        {
            mensajeErrorBarcode = null;
            return;
        }

        var codigoNormalizado = codigoBarras.Trim().ToUpper();

        if (productosPorCodigo.TryGetValue(codigoNormalizado, out var producto))
        {
            mensajeErrorBarcode = null;

            AgregarProductoALista(
                producto.Id,
                cantidadAgregar > 0 ? cantidadAgregar : 1
            );

            codigoBarras = string.Empty; // limpia el input
            cantidadAgregar = 1;
        }
    }

    private void LimpiarCodigoBarras()
    {
        codigoBarras = string.Empty;
        mensajeErrorBarcode = null;
    }

    private void AgregarProductoALista(int productoId, int cantidad)
    {
        var detalleExistente = command.Detalles.FirstOrDefault(d => d.ProductoId == productoId);
        if (detalleExistente != null)
        {
            detalleExistente.Cantidad += cantidad;
        }
        else
        {
            command.Detalles.Add(new DetalleVentaItem
            {
                ProductoId = productoId,
                Cantidad = cantidad
            });
        }
    }

    private void RemoverDetalle(int index)
    {
        if (index >= 0 && index < command.Detalles.Count)
        {
            command.Detalles.RemoveAt(index);
        }
    }

    private void ActualizarCantidad(int index, ChangeEventArgs e)
    {
        if (index >= 0 && index < command.Detalles.Count)
        {
            if (int.TryParse(e.Value?.ToString(), out int nuevaCantidad) && nuevaCantidad > 0)
            {
                command.Detalles[index].Cantidad = nuevaCantidad;
            }
        }
    }

    private void MostrarConfirmacionRegistro()
    {
        mostrarConfirmacion = true;
    }

    private async Task ConfirmarRegistro()
    {
        mostrarConfirmacion = false;
        await HandleValidSubmit();
    }

    private async Task HandleValidSubmit()
    {
        mensajeError = null;

        if (command.Detalles.Count == 0)
        {
            mensajeError = "Debe agregar al menos un producto a la venta.";
            return;
        }

        try
        {
            var venta = await VentaService.CreateAsync(command);
            NavigationManager.NavigateTo($"/ventas/detalles/{venta.Id}");
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
        }
    }
}